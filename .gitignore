# Local deployment/operator config
config/deploy.local.psd1
config/operators.local.json
config/vault-secrets.local.json

# Keys and secret material
**/*.pem
**/*.key
**/*.p12
**/*.pfx

# Terraform local state and plan files
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
crash.log