# Container / SSH
DEV_USERNAME=dev
DEV_UID=1001
DEV_GID=1001
SSH_PORT=2222

# Paste the CONTENTS of your local public key here (single line)
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... replace_me

# Git / repo bootstrap
GIT_REPO_URL=https://github.com/GolanLevi/myOS.git
GIT_REF=main
BOOTSTRAP_GIT_SYNC_MODE=resume
GIT_USER_NAME=myOS Agent
GIT_USER_EMAIL=myos-agent@users.noreply.github.com

# GitHub App auth for clone/pull/push
# The container is expected to use this GitHub App path instead of inherited host credentials.
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=12345678
# Local path ON YOUR COMPUTER to the downloaded GitHub App private key PEM.
GH_APP_PRIVATE_KEY_FILE=C:/Users/YOU/secrets/myos-github-app.private-key.pem
GITHUB_API_URL=https://api.github.com

# Codex / tmux behavior
AUTO_ATTACH_TMUX=true
CODEX_AUTO_START=true
TMUX_SESSION_NAME=codex
CODEX_SANDBOX_MODE=danger-full-access
CODEX_APPROVAL_POLICY=never
CODEX_ENABLE_WEB_SEARCH=false

# Optional developer-specific instruction file under docs/instructions/users/
# Example: `amit` loads docs/instructions/users/amit.md if it exists.
MYOS_OPERATOR_INSTRUCTIONS=amit
